---
import "@/styles/fonts.css";
import "@/styles/typography.css";
import "@/styles/global.css";
import BgChanger from "@/components/BgChanger.astro";
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <link rel="shortcut icon" type="image/x-icon" href="/favicon.ico">
    <meta name="viewport" content="width=device-width" />
    <link rel="preload" as="image" href="/images/background-default.webp" fetchpriority="high">
    <link rel="preload" as="image" href="/images/background-highlight.webp" fetchpriority="high">
    <link rel="preload" as="font" type="font/ttf" href="/fonts/Roboto-VariableFont.ttf" crossorigin="anonymous">
