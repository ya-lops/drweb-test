    <link rel="preload" as="font" type="font/ttf" href="/fonts/FreeSetDemiC.woff2" crossorigin="anonymous">
    <link rel="preload" as="font" type="font/ttf" href="/fonts/FreeSetExtraBoldC.woff2" crossorigin="anonymous">
    <title>test - drweb</title>
  </head>
  <body>
    <slot />
    <BgChanger/>
  </body>
