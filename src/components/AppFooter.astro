---
import Container from "./Container.astro";
import FooterIcon from "@/icons/drweb-logo-small.svg";
import SocialLinks from "./SocialLinks.astro";
---

<footer class="drw-footer">
  <Container>
    <div class="_drw-footer-inner">
      <nav class="_drw-footer-nav +typo-body">
        <div class="_drw-footer-group">
          <a href="#">Для дома</a>
          <a href="#">Для бизнеса</a>
          <a href="#">Поддержка</a>
        </div>
        <div class="_drw-footer-group">
          <a href="#">Пользователям</a>
          <a href="#">Партнерам</a>
          <a href="#">О компании</a>
        </div>
        <div class="_drw-footer-group">
          <a href="#">Контакты</a>
          <a href="#">Вакансии</a>
          <div class="_drw-footer-socials">
            <SocialLinks />
          </div>
        </div>
      </nav>

      <aside class="_drw-footer-links +typo-caption">
        <div class="_drw-footer-group">
          <div class="_drw-footer-info">
            <div class="_drw-footer-copy">
              <FooterIcon />
              <span>© «Доктор Веб» 2003–2025</span>
            </div>
            <p>
              «Доктор Веб» — российский производитель антивирусных средств
              защиты информации под маркой Dr.Web.
            </p>
          </div>
        </div>
        <div class="_drw-footer-group">
          <a href="#">Обработка персональных данных</a>
          <a href="#">Безопасная разработка и выпуск обновлений</a>
        </div>
        <div class="_drw-footer-group">
          <a href="#">Политика конфиденциальности</a>
          <a href="#">Информация по требованиям Минцифры России</a>
        </div>
      </aside>
    </div>
  </Container>
</footer>

<style is:global>
  .drw-footer {
    padding-block: var(--drw-gap-16);
    background: var(--drw-color-surface-secondary);
    color: var(--drw-color-text-secondary-muted);

    @media (width < 768px) {
      padding-block: var(--drw-gap-12);
    }

    a {
      color: inherit;
      text-decoration: none;

      &:hover {
        text-decoration: underline;
      }
    }

    ._drw-footer-nav {
      display: flex;
      gap: var(--drw-gap-8);
      margin-bottom: var(--drw-gap-12);

      @media (width < 768px) {
        flex-wrap: wrap;
        gap: var(--drw-gap-4) var(--drw-gap-5);
        margin-bottom: var(--drw-gap-8);
      }
    }

    ._drw-footer-group {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: var(--drw-gap-6);

      @media (width < 768px) {
        display: contents;
      }
    }

    ._drw-footer-links {
      display: flex;
      flex-wrap: wrap;
      gap: var(--drw-gap-8);
      padding-top: var(--drw-gap-4);
      border-top: 1px solid var(--drw-color-line-edge);

      ._drw-footer-group {
        gap: var(--drw-gap-3);

        &:nth-child(1) {
          @media (1024px > width > 768px) {
            flex-basis: 100%;
          }
        }
      }

      @media (width < 768px) {
        flex-direction: column;
        gap: var(--drw-gap-3);
      }
    }

    ._drw-footer-copy {
      display: flex;
      align-items: center;
      gap: var(--drw-gap-3);
      margin-bottom: var(--drw-gap-2);
    }
  }
</style>
