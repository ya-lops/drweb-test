---
import Button from "./Button.astro";
import Dialog from "./forms/Dialog.astro";
import InputCheckbox from "./forms/InputCheckbox.astro";
import InputText from "./forms/InputText.astro";
---

<div x-data="registrationForm()">
  <form class="drw-reg-form" @submit.prevent="submitForm" novalidate>
    <InputText
      id="reg-form-name"
      label="Фамилия, имя"
      x-model="form.name"
      :class="{ '+error': errors.name, '+filled': form.name.length }"
      @input="clearError('name')"
    />
    <InputText
      id="reg-form-company"
      label="Компания"
      x-model="form.company"
      :class="{ '+error': errors.company, '+filled': form.company.length }"
      @input="clearError('company')"
    />
    <InputText
      id="reg-form-job"
      label="Должность"
      x-model="form.job"
      :class="{ '+error': errors.job, '+filled': form.job.length }"
      @input="clearError('job')"
    />
    <InputText
      id="reg-form-mail"
      label="E-mail"
      type="email"
      errorField="email"
      x-model="form.email"
      :class="{ '+error': errors.email, '+filled': form.email.length }"
      @input="clearError('email')"
    />
    <InputText
      id="reg-form-phone"
      label="Телефон"
      x-model="form.phone"
      :class="{ '+error': errors.phone, '+filled': form.phone.length }"
      @input="clearError('phone')"
    />

    <p
      x-show="form.email.length > 0"
      class="_reg-form-warning-message +typo-caption"
    >
      Обратите внимание на правильность указания адреса электронной почты: на
      него придет подтверждение регистрации.
    </p>

    <p class="_reg-form-message +typo-caption">
      Все поля обязательны для заполнения!
    </p>

    <InputCheckbox
      id="reg-form-agreement-check"
      errorField="agreement"
      :class="{ '+error': errors.agreement, '+filled': form.agreement }"
      x-model="form.agreement"
      @change="clearError('agreement')"
    >
      Я даю согласие на обработку моих персональных данных в соответствии с <a
        href="#link-to-policy">Политикой конфиденциальности</a
      >
    </InputCheckbox>

    <!-- Ошибка отправки -->
    <p
      x-show="submitError"
      class="_submit-error +typo-caption"
      x-text="submitError"
    >
    </p>

    <Button variant="primary" :disabled="isSubmitting">
      <span x-show="!isSubmitting">Зарегистрироваться</span>
      <span x-show="isSubmitting" class="_btn-loading">
        <span class="_spinner"></span>
      </span>
    </Button>

    <span class="_spinner"></span>
  </form>

  <Dialog
    id="successDialog"
    x-ref="successDialog"
    title="Регистрация прошла успешно!"
    closeBtnClick="closeDialog"
  >
    <p>В течение 24 часов вы получите письмо с подтверждением регистрации.</p>
    <Button slot="actions" variant="primary" @click="closeDialog">
      Хорошо
    </Button>
  </Dialog>

  <Dialog
    id="sentErrorDialog"
    x-ref="sentErrorDialog"
    title="Что-то пошло не так"
    closeBtnClick="closeDialog"
  >
    <p>Перезагрузите страницу или зайдите позже</p>
    <Button slot="actions" variant="primary" @click="closeDialog">
      Хорошо
    </Button>
  </Dialog>
</div>

<style is:global>
  .drw-reg-form {
    display: flex;
    flex-direction: column;
    gap: var(--drw-gap-4);

    ._reg-form-message {
      color: var(--drw-color-text-disabled);
    }

    ._reg-form-warning-message {
      margin-block: var(--drw-gap-4);
      padding: var(--drw-gap-4) var(--drw-gap-6);
      border: 1px solid var(--drw-color-status-error);
      border-radius: 10px;
      background-color: var(--drw-color-surface-tertiary);
      color: var(--drw-color-text-primary);
      transition: 0.25s;
      transition-property: translate, opacity;

      @starting-style {
        translate: 0 -20px;
        opacity: 0;
      }
    }

    /* Стили для кнопки при загрузке */
    button[disabled] {
      opacity: 0.7;
      cursor: not-allowed;
    }

    ._btn-loading {
      display: flex;
      align-items: center;
      gap: var(--drw-gap-2);
    }

    ._spinner {
      display: inline-block;
      width: 16px;
      height: 16px;
      border: 2px solid var(--drw-color-bg-primary);
      border-top-color: transparent;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    /* Сообщение об ошибке отправки */
    ._submit-error {
      padding: var(--drw-gap-3) var(--drw-gap-4);
      background-color: var(--drw-color-status-error);
      color: white;
      border-radius: var(--drw-radius-1);
      font-size: 14px;
      text-align: center;
    }
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>

<script is:inline>
  function registrationForm() {
    return {
      form: {
        name: "",
        company: "",
        job: "",
        email: "",
        phone: "",
        agreement: false,
      },
      errors: {},
      isSubmitting: false,
      submitError: null,

      clearError(fieldName) {
        if (this.errors[fieldName]) {
          delete this.errors[fieldName];
        }
      },

      validateEmail(email) {
        const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        return re.test(email);
      },

      validatePhone(phone) {
        const re = /^(\+7|8)[\d\s\-\(\)]{9,11}$/;
        const digits = phone.replace(/\D/g, "");
        return digits.length >= 10 && digits.length <= 11;
      },

      validateForm() {
        const newErrors = {};

        if (!this.form.name.trim()) {
          newErrors.name = "Укажите данные";
        } else if (this.form.name.trim().length < 2) {
          newErrors.name = "Слишком короткое имя";
        }

        if (!this.form.company.trim()) {
          newErrors.company = "Укажите данные";
        }

        if (!this.form.job.trim()) {
          newErrors.job = "Укажите данные";
        }

        if (!this.form.email.trim()) {
          newErrors.email = "Укажите данные";
        } else if (!this.validateEmail(this.form.email)) {
          newErrors.email = "Некорректный e-mail";
        }

        if (!this.form.phone.trim()) {
          newErrors.phone = "Укажите данные";
        } else if (!this.validatePhone(this.form.phone)) {
          newErrors.phone = "Некорректный номер телефона";
        }

        // Проверка согласия
        if (!this.form.agreement) {
          newErrors.agreement = "Необходимо согласие";
        }

        this.errors = newErrors;

        return Object.keys(newErrors).length === 0;
      },

      async submitForm() {
        this.submitError = null;

        if (!this.validateForm()) {
          const firstError = document.querySelector(
            ".\\+error",
          );
          if (firstError) {
            firstError.scrollIntoView({ behavior: "smooth", block: "center" });
          }
          return;
        }

        this.isSubmitting = true;

        try {
          await this.fakeSubmit();

          this.$refs.successDialog.showModal();
          this.resetForm();
        } catch (error) {
          this.$refs.sentErrorDialog.showModal();
        } finally {
          this.isSubmitting = false;
        }
      },

      async fakeSubmit() {
        return new Promise((resolve, reject) => {
          setTimeout(() => {
            if (Math.random() > 0.5) {
              console.log("Отправленные данные:", {
                name: this.form.name,
                company: this.form.company,
                job: this.form.job,
                email: this.form.email,
                phone: this.form.phone,
                agreement: this.form.agreement,
              });
              resolve(true);
            } else {
              reject(new Error("Server error"));
            }
          }, 1500);
        });
      },

      resetForm() {
        this.form = {
          name: "",
          company: "",
          job: "",
          email: "",
          phone: "",
          agreement: false,
        };
        this.errors = {};
      },

      closeDialog() {
        if (this.$refs.successDialog) {
          this.$refs.successDialog.close();
        }
        if (this.$refs.sentErrorDialog) {
          this.$refs.sentErrorDialog.close();
        }
      },
    };
  }
</script>