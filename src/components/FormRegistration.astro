---
import Button from "./Button.astro";
import Dialog from "./forms/Dialog.astro";
import InputCheckbox from "./forms/InputCheckbox.astro";
import InputText from "./forms/InputText.astro";
---

<div x-data="registrationForm()">
  <form class="drw-reg-form" @submit.prevent="submitForm">
    <InputText
      id="reg-form-name"
      label="Фамилия, имя"
      x-model="form.name"
      :class="{ '+error': errors.name }"
      @input="clearError('name')"
    />
    <InputText
      id="reg-form-company"
      label="Компания"
      x-model="form.company"
      :class="{ '+error': errors.company }"
      @input="clearError('company')"
    />
    <InputText
      id="reg-form-job"
      label="Должность"
      x-model="form.job"
      :class="{ '+error': errors.job }"
      @input="clearError('job')"
    />
    <InputText
      id="reg-form-mail"
      label="E-mail"
      type="email"
      x-model="form.email"
      :class="{ '+error': errors.email }"
      @input="clearError('email')"
    />
    <InputText
      id="reg-form-phone"
      label="Телефон"
      x-model="form.phone"
      :class="{ '+error': errors.phone }"
      @input="clearError('phone')"
    />

    <p
      x-show="form.email.length > 0"
      class="_reg-form-warning-message +typo-caption"
    >
      Обратите внимание на правильность указания адреса электронной почты: на
      него придет подтверждение регистрации.
    </p>

    <p class="_reg-form-message +typo-caption">
      Все поля обязательны для заполнения!
    </p>

    <InputCheckbox
      id="reg-form-agreement-check"
      :class="{ '+error': errors.agreement }"
      x-model="form.agreement"
      @change="clearError('agreement')"
    >
      Я даю согласие на обработку моих персональных данных в соответствии с <a
        href="#link-to-policy">Политикой конфиденциальности</a
      >
    </InputCheckbox>
    <Button variant="primary">Зарегистрироваться</Button>
  </form>

  <Dialog
    id="successDialog"
    x-ref="successDialog"
    title="Регистрация прошла успешно!"
    closeBtnClick="closeDialog"
  >
    <p>В течение 24 часов вы получите письмо с подтверждением регистрации.</p>
    <Button slot="actions" variant="primary" @click="closeDialog"> Хорошо </Button>
  </Dialog>
</div>

<style is:global>
  .drw-reg-form {
    display: flex;
    flex-direction: column;
    gap: var(--drw-gap-4);

    ._reg-form-message {
      color: var(--drw-color-text-disabled);
    }

    ._reg-form-warning-message {
      margin-block: var(--drw-gap-4);
      padding: var(--drw-gap-4) var(--drw-gap-6);
      border: 1px solid var(--drw-color-status-error);
      border-radius: 10px;
      background-color: var(--drw-color-surface-tertiary);
      color: var(--drw-color-text-primary);
      transition: .25s;
      transition-property: translate, opacity;

      @starting-style {
        translate: 0 -20px;
        opacity: 0;
      }
    }
  }

  
</style>

<script is:inline>
  function registrationForm() {
    return {
      form: {
        name: "",
        company: "",
        job: "",
        email: "",
        phone: "",
        agreement: false,
      },
      errors: {},

      clearError(fieldName) {
        if (this.errors[fieldName]) {
          delete this.errors[fieldName];
        }
      },

      validateForm() {
        const newErrors = {};

        // Проверка всех полей на заполнение
        if (!this.form.name.trim()) newErrors.name = true;
        if (!this.form.company.trim()) newErrors.company = true;
        if (!this.form.job.trim()) newErrors.job = true;
        if (!this.form.email.trim()) newErrors.email = true;
        if (!this.form.phone.trim()) newErrors.phone = true;
        if (!this.form.agreement) newErrors.agreement = true;

        this.errors = newErrors;

        return Object.keys(newErrors).length === 0;
      },

      submitForm() {
        if (this.validateForm()) {
          this.$refs.successDialog.showModal();
          this.resetForm();
        }
      },

      resetForm() {
        this.form = {
          name: "",
          company: "",
          job: "",
          email: "",
          phone: "",
          agreement: false,
        };
        this.errors = {};
      },

      closeDialog() {
        this.$refs.successDialog.close();
      },
    };
  }
</script>
