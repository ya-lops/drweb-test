---
import Button from "./Button.astro";
import Dialog from "./forms/Dialog.astro";
import InputCheckbox from "./forms/InputCheckbox.astro";
import InputText from "./forms/InputText.astro";
---

<div x-data="registrationForm()">
  <form class="drw-reg-form" @submit.prevent="submitForm">
    <InputText
      id="reg-form-name"
      label="–Λ–Α–Φ–Η–Μ–Η―è, –Η–Φ―è"
      x-model="form.name"
      :class="{ '+error': errors.name, '+filled': form.name.length }"
      @input="clearError('name')"
    />
    <InputText
      id="reg-form-company"
      label="–ö–Ψ–Φ–Ω–Α–Ϋ–Η―è"
      x-model="form.company"
      :class="{ '+error': errors.company, '+filled': form.company.length }"
      @input="clearError('company')"
    />
    <InputText
      id="reg-form-job"
      label="–î–Ψ–Μ–Ε–Ϋ–Ψ―¹―²―¨"
      x-model="form.job"
      :class="{ '+error': errors.job, '+filled': form.job.length }"
      @input="clearError('job')"
    />
    <InputText
      id="reg-form-mail"
      label="E-mail"
      type="email"
      x-model="form.email"
      :class="{ '+error': errors.email, '+filled': form.email.length }"
      @input="clearError('email')"
    />
    <InputText
      id="reg-form-phone"
      label="–Δ–Β–Μ–Β―³–Ψ–Ϋ"
      x-model="form.phone"
      :class="{ '+error': errors.phone, '+filled': form.phone.length }"
      @input="clearError('phone')"
    />

    <p
      x-show="form.email.length > 0"
      class="_reg-form-warning-message +typo-caption"
    >
      –û–±―Ä–Α―²–Η―²–Β –≤–Ϋ–Η–Φ–Α–Ϋ–Η–Β –Ϋ–Α –Ω―Ä–Α–≤–Η–Μ―¨–Ϋ–Ψ―¹―²―¨ ―É–Κ–Α–Ζ–Α–Ϋ–Η―è –Α–¥―Ä–Β―¹–Α ―ç–Μ–Β–Κ―²―Ä–Ψ–Ϋ–Ϋ–Ψ–Ι –Ω–Ψ―΅―²―΄: –Ϋ–Α
      –Ϋ–Β–≥–Ψ –Ω―Ä–Η–¥–Β―² –Ω–Ψ–¥―²–≤–Β―Ä–Ε–¥–Β–Ϋ–Η–Β ―Ä–Β–≥–Η―¹―²―Ä–Α―Ü–Η–Η.
    </p>

    <p class="_reg-form-message +typo-caption">
      –£―¹–Β –Ω–Ψ–Μ―è –Ψ–±―è–Ζ–Α―²–Β–Μ―¨–Ϋ―΄ –¥–Μ―è –Ζ–Α–Ω–Ψ–Μ–Ϋ–Β–Ϋ–Η―è!
    </p>

    <InputCheckbox
      id="reg-form-agreement-check"
      :class="{ '+error': errors.agreement, '+filled': form.agreement }"
      x-model="form.agreement"
      @change="clearError('agreement')"
    >
      –· –¥–Α―é ―¹–Ψ–≥–Μ–Α―¹–Η–Β –Ϋ–Α –Ψ–±―Ä–Α–±–Ψ―²–Κ―É –Φ–Ψ–Η―Ö –Ω–Β―Ä―¹–Ψ–Ϋ–Α–Μ―¨–Ϋ―΄―Ö –¥–Α–Ϋ–Ϋ―΄―Ö –≤ ―¹–Ψ–Ψ―²–≤–Β―²―¹―²–≤–Η–Η ―¹ <a
        href="#link-to-policy">–ü–Ψ–Μ–Η―²–Η–Κ–Ψ–Ι –Κ–Ψ–Ϋ―³–Η–¥–Β–Ϋ―Ü–Η–Α–Μ―¨–Ϋ–Ψ―¹―²–Η</a
      >
    </InputCheckbox>

    <!-- –û―à–Η–±–Κ–Α –Ψ―²–Ω―Ä–Α–≤–Κ–Η -->
    <p
      x-show="submitError"
      class="_submit-error +typo-caption"
      x-text="submitError"
    >
    </p>

    <Button variant="primary" :disabled="isSubmitting">
      <span x-show="!isSubmitting">–½–Α―Ä–Β–≥–Η―¹―²―Ä–Η―Ä–Ψ–≤–Α―²―¨―¹―è</span>
      <span x-show="isSubmitting" class="_btn-loading">
        <span class="_spinner"></span>
      </span>
    </Button>

    <span class="_spinner"></span>
  </form>

  <Dialog
    id="successDialog"
    x-ref="successDialog"
    title="–†–Β–≥–Η―¹―²―Ä–Α―Ü–Η―è –Ω―Ä–Ψ―à–Μ–Α ―É―¹–Ω–Β―à–Ϋ–Ψ!"
    closeBtnClick="closeDialog"
  >
    <p>–£ ―²–Β―΅–Β–Ϋ–Η–Β 24 ―΅–Α―¹–Ψ–≤ –≤―΄ –Ω–Ψ–Μ―É―΅–Η―²–Β –Ω–Η―¹―¨–Φ–Ψ ―¹ –Ω–Ψ–¥―²–≤–Β―Ä–Ε–¥–Β–Ϋ–Η–Β–Φ ―Ä–Β–≥–Η―¹―²―Ä–Α―Ü–Η–Η.</p>
    <Button slot="actions" variant="primary" @click="closeDialog">
      –Ξ–Ψ―Ä–Ψ―à–Ψ
    </Button>
  </Dialog>

  <Dialog
    id="sentErrorDialog"
    x-ref="sentErrorDialog"
    title="–ß―²–Ψ-―²–Ψ –Ω–Ψ―à–Μ–Ψ –Ϋ–Β ―²–Α–Κ"
    closeBtnClick="closeDialog"
  >
    <p>–ü–Β―Ä–Β–Ζ–Α–≥―Ä―É–Ζ–Η―²–Β ―¹―²―Ä–Α–Ϋ–Η―Ü―É –Η–Μ–Η –Ζ–Α–Ι–¥–Η―²–Β –Ω–Ψ–Ζ–Ε–Β</p>
    <Button slot="actions" variant="primary" @click="closeDialog">
      –Ξ–Ψ―Ä–Ψ―à–Ψ
    </Button>
  </Dialog>
</div>

<style is:global>
  .drw-reg-form {
    display: flex;
    flex-direction: column;
    gap: var(--drw-gap-4);

    ._reg-form-message {
      color: var(--drw-color-text-disabled);
    }

    ._reg-form-warning-message {
      margin-block: var(--drw-gap-4);
      padding: var(--drw-gap-4) var(--drw-gap-6);
      border: 1px solid var(--drw-color-status-error);
      border-radius: 10px;
      background-color: var(--drw-color-surface-tertiary);
      color: var(--drw-color-text-primary);
      transition: 0.25s;
      transition-property: translate, opacity;

      @starting-style {
        translate: 0 -20px;
        opacity: 0;
      }
    }

    /* –Γ―²–Η–Μ–Η –¥–Μ―è –Κ–Ϋ–Ψ–Ω–Κ–Η –Ω―Ä–Η –Ζ–Α–≥―Ä―É–Ζ–Κ–Β */
    button[disabled] {
      opacity: 0.7;
      cursor: not-allowed;
    }

    ._btn-loading {
      display: flex;
      align-items: center;
      gap: var(--drw-gap-2);
    }

    ._spinner {
      display: inline-block;
      width: 16px;
      height: 16px;
      border: 2px solid var(--drw-color-bg-primary);
      border-top-color: transparent;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    /* –Γ–Ψ–Ψ–±―â–Β–Ϋ–Η–Β –Ψ–± –Ψ―à–Η–±–Κ–Β –Ψ―²–Ω―Ä–Α–≤–Κ–Η */
    ._submit-error {
      padding: var(--drw-gap-3) var(--drw-gap-4);
      background-color: var(--drw-color-status-error);
      color: white;
      border-radius: var(--drw-radius-1);
      font-size: 14px;
      text-align: center;
    }
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>

<script is:inline>
  function registrationForm() {
    return {
      form: {
        name: "",
        company: "",
        job: "",
        email: "",
        phone: "",
        agreement: false,
      },
      errors: {},
      isSubmitting: false,
      submitError: null,

      clearError(fieldName) {
        if (this.errors[fieldName]) {
          delete this.errors[fieldName];
        }
      },

      validateEmail(email) {
        const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        return re.test(email);
      },

      validatePhone(phone) {
        // –†–Ψ―¹―¹–Η–Ι―¹–Κ–Η–Ι –Ϋ–Ψ–Φ–Β―Ä: +7, 8, –Η–Μ–Η 10-11 ―Ü–Η―³―Ä
        const re = /^(\+7|8)[\d\s\-\(\)]{9,11}$/;
        const digits = phone.replace(/\D/g, "");
        return digits.length >= 10 && digits.length <= 11;
      },

      validateForm() {
        const newErrors = {};

        // –ü―Ä–Ψ–≤–Β―Ä–Κ–Α –Η–Φ–Β–Ϋ–Η (–Φ–Η–Ϋ–Η–Φ―É–Φ 2 ―¹–Η–Φ–≤–Ψ–Μ–Α)
        if (!this.form.name.trim()) {
          newErrors.name = "–Θ–Κ–Α–Ε–Η―²–Β –Λ–‰–û";
        } else if (this.form.name.trim().length < 2) {
          newErrors.name = "–Γ–Μ–Η―à–Κ–Ψ–Φ –Κ–Ψ―Ä–Ψ―²–Κ–Ψ–Β –Η–Φ―è";
        }

        // –ü―Ä–Ψ–≤–Β―Ä–Κ–Α –Κ–Ψ–Φ–Ω–Α–Ϋ–Η–Η
        if (!this.form.company.trim()) {
          newErrors.company = "–Θ–Κ–Α–Ε–Η―²–Β –Ϋ–Α–Ζ–≤–Α–Ϋ–Η–Β –Κ–Ψ–Φ–Ω–Α–Ϋ–Η–Η";
        }

        // –ü―Ä–Ψ–≤–Β―Ä–Κ–Α –¥–Ψ–Μ–Ε–Ϋ–Ψ―¹―²–Η
        if (!this.form.job.trim()) {
          newErrors.job = "–Θ–Κ–Α–Ε–Η―²–Β –¥–Ψ–Μ–Ε–Ϋ–Ψ―¹―²―¨";
        }

        // –ü―Ä–Ψ–≤–Β―Ä–Κ–Α email
        if (!this.form.email.trim()) {
          newErrors.email = "–Θ–Κ–Α–Ε–Η―²–Β e-mail";
        } else if (!this.validateEmail(this.form.email)) {
          newErrors.email = "–ù–Β–Κ–Ψ―Ä―Ä–Β–Κ―²–Ϋ―΄–Ι e-mail";
        }

        // –ü―Ä–Ψ–≤–Β―Ä–Κ–Α ―²–Β–Μ–Β―³–Ψ–Ϋ–Α
        if (!this.form.phone.trim()) {
          newErrors.phone = "–Θ–Κ–Α–Ε–Η―²–Β ―²–Β–Μ–Β―³–Ψ–Ϋ";
        } else if (!this.validatePhone(this.form.phone)) {
          newErrors.phone = "–ù–Β–Κ–Ψ―Ä―Ä–Β–Κ―²–Ϋ―΄–Ι –Ϋ–Ψ–Φ–Β―Ä ―²–Β–Μ–Β―³–Ψ–Ϋ–Α";
        }

        // –ü―Ä–Ψ–≤–Β―Ä–Κ–Α ―¹–Ψ–≥–Μ–Α―¹–Η―è
        if (!this.form.agreement) {
          newErrors.agreement = "–ù–Β–Ψ–±―Ö–Ψ–¥–Η–Φ–Ψ ―¹–Ψ–≥–Μ–Α―¹–Η–Β –Ϋ–Α –Ψ–±―Ä–Α–±–Ψ―²–Κ―É –¥–Α–Ϋ–Ϋ―΄―Ö";
        }

        this.errors = newErrors;

        return Object.keys(newErrors).length === 0;
      },

      async submitForm() {
        this.submitError = null;

        if (!this.validateForm()) {
          const firstError = document.querySelector(
            ".\\+error",
          );
          if (firstError) {
            firstError.scrollIntoView({ behavior: "smooth", block: "center" });
          }
          return;
        }

        this.isSubmitting = true;

        try {
          await this.fakeSubmit();

          this.$refs.successDialog.showModal();
          this.resetForm();
        } catch (error) {
          this.$refs.sentErrorDialog.showModal();
        } finally {
          this.isSubmitting = false;
        }
      },

      async fakeSubmit() {
        return new Promise((resolve, reject) => {
          setTimeout(() => {
            if (Math.random() > 0.5) {
              console.log("–û―²–Ω―Ä–Α–≤–Μ–Β–Ϋ–Ϋ―΄–Β –¥–Α–Ϋ–Ϋ―΄–Β:", {
                name: this.form.name,
                company: this.form.company,
                job: this.form.job,
                email: this.form.email,
                phone: this.form.phone,
                agreement: this.form.agreement,
                timestamp: new Date().toISOString(),
              });
              resolve(true);
            } else {
              reject(new Error("Server error"));
            }
          }, 1500);
        });
      },

      resetForm() {
        this.form = {
          name: "",
          company: "",
          job: "",
          email: "",
          phone: "",
          agreement: false,
        };
        this.errors = {};
      },

      closeDialog() {
        if (this.$refs.successDialog) {
          this.$refs.successDialog.close();
        }
        if (this.$refs.sentErrorDialog) {
          this.$refs.sentErrorDialog.close();
        }
      },
    };
  }
</script>